#!/usr/bin/env bash
# Reject commit messages that contain AI attribution.
#
# Sparks is a public repo. Per maintainer policy, no AI / LLM / model-name
# attribution belongs in commit messages, Co-Authored-By trailers, or
# generated-by footers. Product-name references (e.g. "Claude Code as
# an agent harness") in code/docs are fine — this hook only inspects
# commit message content.
#
# Enable once per clone:   git config core.hooksPath .githooks

set -e
msg_file=$1
[ -z "$msg_file" ] && exit 0

# Co-authored-by trailers naming AI vendors / models.
if grep -qiE '^Co-[Aa]uthored-[Bb]y:.*(claude|anthropic|openai|gpt|codex|gemini|copilot|llm|ai-assistant)' "$msg_file"; then
  echo "commit-msg: rejected — AI attribution in Co-Authored-By trailer." >&2
  echo "  Strip the trailer and re-commit." >&2
  exit 1
fi

# "Generated with X" / robot-emoji footers.
if grep -qE '🤖|Generated with .*(Claude|Codex|Copilot|GPT|AI|LLM|ChatGPT)' "$msg_file"; then
  echo "commit-msg: rejected — AI generation footer in commit message." >&2
  exit 1
fi

# Email addresses that out an AI co-author.
if grep -qiE '(noreply@anthropic\.com|noreply@openai\.com|copilot.*@github\.com)' "$msg_file"; then
  echo "commit-msg: rejected — AI vendor email in commit message." >&2
  exit 1
fi

exit 0
